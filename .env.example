# Supabase Project Settings > API에서 확인
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 문의 삭제용 관리자 키. 원하는 긴 문자열로 직접 지정하세요.
ADMIN_DELETE_KEY=change-this-admin-delete-key

# 개인별 연봉정보 로그인 토큰 서명용. 반드시 긴 랜덤 문자열로 지정하세요.
SALARY_JWT_SECRET=change-this-long-random-salary-secret
